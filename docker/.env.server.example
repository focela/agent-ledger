# Compose env_file (optional, gitignored). Copy to .env.server:
#   cp .env.server.example .env.server

# Uncomment to replace (not append to) the default localhost origins.
# Comma-separated. Each value must start with http:// or https://.
# AGENT_LEDGER_CORS_ORIGINS=http://localhost:3111,http://localhost:3113,http://127.0.0.1:3111,http://127.0.0.1:3113

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
